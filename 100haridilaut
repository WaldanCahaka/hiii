-- // VEHICLE JUMP FUNCTION // --
local function DoVehicleJump()
    if LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if humanoid and rootPart then
            rootPart.Velocity = Vector3.new(
                rootPart.Velocity.X,
                50,
                rootPart.Velocity.Z
            )
        end
    end
end

-- // CREATE JUMP GUI (PC & MOBILE) // --
local function CreateJumpGUI()
    if MobileJumpGUI then MobileJumpGUI:Destroy() end
    
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "REU_VehicleJump"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    
    -- FRAME (DESAIN ASLI)
    local mainButton = Instance.new("Frame")
    mainButton.Size = UDim2.new(0, 130, 0, 55)
    mainButton.Position = UDim2.new(0.8, -65, 0.6, 0)
    mainButton.BackgroundColor3 = Color3.fromRGB(26,26,46)
    mainButton.BorderSizePixel = 0
    mainButton.Parent = screenGui
    
    Instance.new("UICorner", mainButton).CornerRadius = UDim.new(0, 12)
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(48,255,106)
    stroke.Thickness = 3
    stroke.Parent = mainButton
    
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(48,255,106)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(231,255,47))
    })
    gradient.Rotation = 45
    gradient.Parent = mainButton
    
    -- TEXT (TERANG)
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "HOLD JUMP"
    textLabel.TextColor3 = Color3.fromRGB(255,255,255)
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Parent = mainButton
    
    -- BUTTON (BUAT INPUT)
    local clickButton = Instance.new("TextButton")
    clickButton.Size = UDim2.new(1,0,1,0)
    clickButton.BackgroundTransparency = 1
    clickButton.Text = ""
    clickButton.Parent = mainButton
    
    -- HOLD SYSTEM (INI YANG LU MAU)
    local holding = false
    
    clickButton.MouseButton1Down:Connect(function()
        holding = true
        while holding do
            DoVehicleJump()
            task.wait(0.1)
        end
    end)
    
    clickButton.MouseButton1Up:Connect(function()
        holding = false
    end)
    
    MobileJumpGUI = screenGui
end

