local function scanTpParts()
    local foundList = {}
    local uniqueNames = {}
    
    if tpPartInput == "" then 
        WindUI:Notify({ Title = "Info", Content = "Masukkan nama part dulu!", Duration = 3 }) 
        return 
    end
    
    local lowerSearch = string.lower(tpPartInput)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            if string.find(string.lower(obj.Name), lowerSearch, 1, true) then
                uniqueNames[obj.Name] = true
            end
        end
    end
    
    for name, _ in pairs(uniqueNames) do
        table.insert(foundList, name)
    end
    
    if #foundList > 0 then
        TpPartDropdown:Refresh(foundList)
        WindUI:Notify({ Title = "Scan Complete", Content = string.format("Found %d items.", #foundList), Duration = 5 })
    else
        TpPartDropdown:Refresh({"No Results"})
    end
end

