-- =========================================
-- THE GHOST ENGINE (BYPASS TANPA MODIF METATABLE)
-- =========================================
-- Kita pake loop Heartbeat buat maksa state player, 
-- tanpa nyentuh fungsi Kick game biar gak kedetect 0x3.

RunService.Heartbeat:Connect(function(dt)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- 1. STEALTH NOCLIP (NO GRAVITY LOCK)
    if noclipBypassActive then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end

    -- 2. SMART POSITION SYNC (BYPASS PULLBACK)
    if (speedBypassActive or cframeEnabled) and hum.MoveDirection.Magnitude > 0 then
        local targetSpeed = speedBypassActive and customWalkspeed or (16 + speed)
        
        -- Kita pake Velocity horisontal aja biar Gravitasi (Y) tetep jalan
        local moveVel = hum.MoveDirection * targetSpeed
        hrp.Velocity = Vector3.new(moveVel.X, hrp.Velocity.Y, moveVel.Z)
        
        -- Pake Lerp dikit biar gak karet (Rubberband)
        hrp.CFrame = hrp.CFrame:Lerp(hrp.CFrame + (hum.MoveDirection * 0.1), 0.5)
        
        -- SPOOFING: Balikin Walkspeed asli ke 16 tiap frame biar script deteksi Adonis dapet nilai normal
        hum.WalkSpeed = 16
    else
        if not speedBypassActive then hum.WalkSpeed = 16 end
    end
end)

