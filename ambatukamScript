local function cleanFloat()
    if floatUpdateConn then floatUpdateConn:Disconnect(); floatUpdateConn = nil end
    if bodyPos then bodyPos:Destroy(); bodyPos = nil end
    if floatBlock then floatBlock:Destroy(); floatBlock = nil end
    floatActive = false
    if floatGuiInstance and floatGuiInstance:FindFirstChild("DragFrame", true) then
        local btn = floatGuiInstance.DragFrame:FindFirstChild("FloatButton", true)
        if btn then btn.Text = "Float: OFF" end
    end
    if floatToggleRef then floatToggleRef:SetState(false) end
end

local function startFloat()
    local character = LocalPlayer.Character
    if not character then return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid then return false end
    floatActive = true
    floatBlock = Instance.new("Part")
    floatBlock.Size = Vector3.new(6, 1, 6)
    floatBlock.Anchored = true
    floatBlock.CanCollide = true
    floatBlock.Transparency = 0.3
    floatBlock.Material = Enum.Material.Neon
    floatBlock.BrickColor = BrickColor.new("Bright green")
    floatBlock.Parent = workspace
    bodyPos = Instance.new("BodyPosition")
    bodyPos.MaxForce = Vector3.new(0, 0, 0) 
    bodyPos.P = 10000
    bodyPos.D = 1000
    bodyPos.Parent = rootPart
    floatUpdateConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not (floatBlock and rootPart and bodyPos and floatActive) then return end
        if not rootPart:IsDescendantOf(workspace) then cleanFloat(); return end
        local isJumping = humanoid:GetState() == Enum.HumanoidStateType.Jumping or humanoid:GetState() == Enum.HumanoidStateType.Freefall
        if isJumping then
            bodyPos.MaxForce = Vector3.new(0, 0, 0) 
        else
            bodyPos.Position = rootPart.Position
            bodyPos.MaxForce = Vector3.new(0, math.huge, 0) 
        end
        floatBlock.CFrame = CFrame.new(rootPart.Position - Vector3.new(0, 3.5, 0))
    end)
    return true
end

local function toggleFloatLogic(state)
    if state == nil then state = not floatActive end
    if state then
        if startFloat() then
            if floatGuiInstance then
                local btn = floatGuiInstance:FindFirstChild("FloatButton", true)
                if btn then btn.Text = "Float: ON" end
            end
            if floatToggleRef then floatToggleRef:SetState(true) end
        else
            cleanFloat()
        end
    else
        cleanFloat() 
    end
end

