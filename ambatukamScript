local function createGhostGui()
    if ghostGuiInstance then return end

    local ScreenGui = Instance.new("ScreenGui")
    local DragFrame = Instance.new("Frame")
    local GhostButton = Instance.new("TextButton")

    ScreenGui.Name = "GhostGui"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    DragFrame.Name = "DragFrame"
    DragFrame.Parent = ScreenGui
    DragFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    DragFrame.BorderSizePixel = 0
    DragFrame.Size = UDim2.new(0, 200, 0, 80)
    DragFrame.Position = UDim2.new(0.6, 0, 0.4, 0) 
    DragFrame.ZIndex = 1
    DragFrame.Active = true

    GhostButton.Name = "GhostButton"
    GhostButton.Parent = DragFrame
    GhostButton.BackgroundColor3 = Color3.fromRGB(150, 50, 150) 
    GhostButton.Size = UDim2.new(1, 0, 0.5, 0)
    GhostButton.Position = UDim2.new(0, 0, 0, 0)
    GhostButton.Font = Enum.Font.SourceSans
    GhostButton.Text = "Ghost: OFF"
    GhostButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    GhostButton.TextSize = 20
    GhostButton.ZIndex = 2
    GhostButton.Active = true

    ghostGuiInstance = ScreenGui

    -- Manual Drag
    DragFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDraggingGhost = true
            dragStartGhost = input.Position
            startPosGhost = DragFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then isDraggingGhost = false end
            end)
        end
    end)

    DragFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInputGhost = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInputGhost and isDraggingGhost then
            local delta = input.Position - dragStartGhost
            DragFrame.Position = UDim2.new(startPosGhost.X.Scale, startPosGhost.X.Offset + delta.X, startPosGhost.Y.Scale, startPosGhost.Y.Offset + delta.Y)
        end
    end)

    GhostButton.MouseButton1Click:Connect(function()
        toggleGhostLogic(nil)
    end)
end

