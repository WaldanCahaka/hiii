TeleportTab:Button({
    Title = "Teleport to Selected Item",
    Callback = function()
        if selectedTpPartName == "" or selectedTpPartName == "Empty" then
            WindUI:Notify({ Title = "Error", Content = "Pilih item dulu!", Duration = 3 })
            return
        end

        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        local targetsToVisit = {}
        for _, obj in pairs(workspace:GetDescendants()) do
            if (obj:IsA("BasePart") or obj:IsA("Model")) and obj.Name == selectedTpPartName then
                table.insert(targetsToVisit, obj)
            end
        end

        if #targetsToVisit == 0 then
            WindUI:Notify({ Title = "Error", Content = "Objek tidak ditemukan.", Duration = 3 })
            return
        end

        WindUI:Notify({ Title = "Teleport", Content = string.format("Teleporting to %d items...", #targetsToVisit), Duration = 3 })

        for index, targetObj in pairs(targetsToVisit) do
            if not myHRP then break end
            
            local pos3D = nil
            
            if targetObj:IsA("Model") then
                if targetObj.PrimaryPart then
                    pos3D = targetObj.PrimaryPart.Position
                elseif targetObj:FindFirstChild("Handle") then
                    pos3D = targetObj.Handle.Position
                elseif targetObj:FindFirstChild("HumanoidRootPart") then
                    pos3D = targetObj.HumanoidRootPart.Position
                else
                    for _, child in pairs(targetObj:GetChildren()) do
                        if child:IsA("BasePart") then
                            pos3D = child.Position
                            break
                        end
                    end
                end
            elseif targetObj:IsA("BasePart") then
                pos3D = targetObj.Position
            end

            if pos3D then
                local h = Instance.new("Highlight")
                h.FillColor = Color3.fromRGB(0, 255, 255)
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.FillTransparency = 0.5
                h.Adornee = targetObj
                h.Parent = targetObj
                
                myHRP.CFrame = CFrame.new(pos3D + Vector3.new(0, 3, 0))
                
                task.delay(3, function()
                    if h then h:Destroy() end
                end)
                
                task.wait(0.5)
            end
        end
        
        WindUI:Notify({ Title = "Done", Content = "Teleport sequence finished.", Duration = 3 })
    end
})

