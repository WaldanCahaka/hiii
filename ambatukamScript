local function attackTargetFixed(targetChar)
    local char = LocalPlayer.Character
    if not char then return end
    
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool or not tool:FindFirstChild("Handle") then return end
    
    local handle = tool.Handle
    local hum = targetChar:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end

    tool:Activate()
    for _, part in pairs(targetChar:GetChildren()) do
        if part:IsA("BasePart") then
            firetouchinterest(handle, part, 0)
            task.wait()
            firetouchinterest(handle, part, 1)
        end
    end
end

local function findTargetPlayer(inputName)
    local lowerInput = string.lower(inputName)
    local foundPlayers = {}
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if string.lower(plr.Name) == lowerInput or string.find(string.lower(plr.Name), lowerInput) then
                table.insert(foundPlayers, plr)
            elseif string.lower(plr.DisplayName) == lowerInput or string.find(string.lower(plr.DisplayName), lowerInput) then
                table.insert(foundPlayers, plr)
            end
        end
    end
    return foundPlayers
end

