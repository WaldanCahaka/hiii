-- Function to create ESP objects for a player
local function setupESP(plr)
    if plr == LocalPlayer then return end
    
    -- Clean up existing objects first
    local existing = ESP.Objects[plr]
    if existing then
        for _, d in pairs({existing.Box, existing.Name, existing.Distance, existing.Tracer}) do if d then d:Remove() end end
        if existing.HealthBar then for _, d in pairs(existing.HealthBar) do if d then d:Remove() end end end
        for _, l in pairs(existing.Skeleton) do if l then l:Remove() end end
    end

    ESP.Objects[plr] = {
        Box = newDrawing("Square", { Thickness = 2.5, Color = Color3.new(1, 1, 1), Filled = false }),
        Name = newDrawing("Text", { Size = 13, Center = true, Outline = true, Color = Color3.new(1, 1, 1) }),
        Distance = newDrawing("Text", { Size = 13, Center = true, Outline = true, Color = Color3.new(1, 1, 1) }),
        Tracer = newDrawing("Line", { Thickness = 1, Color = Color3.new(1, 1, 1) }),
        HealthBar = {
            Outline = newDrawing("Square", { Color = Color3.new(0, 0, 0), Filled = true }),
            Health = newDrawing("Square", { Color = Color3.new(0, 1, 0), Filled = true })
        },
        Skeleton = {}
    }
end

-- Function to remove ESP objects
local function removeESP(plr)
    local entries = ESP.Objects[plr]
    if entries then
        for _, d in pairs({entries.Box, entries.Name, entries.Distance, entries.Tracer}) do if d then d:Remove() end end
        if entries.HealthBar then for _, d in pairs(entries.HealthBar) do if d then d:Remove() end end end
        for _, l in pairs(entries.Skeleton) do if l then l:Remove() end end
        ESP.Objects[plr] = nil
    end
end

-- Main Render Loop
RunService.RenderStepped:Connect(function()
    local lChar = LocalPlayer.Character
    local lHRP = lChar and lChar:FindFirstChild("HumanoidRootPart")
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local entries = ESP.Objects[plr]
            
            -- Conditions to hide ESP (Disabled, No Char, No HRP, No Humanoid)
            if not ESP.Enabled or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") or not plr.Character:FindFirstChild("Humanoid") then
                if entries then
                    -- Hide all drawings efficiently
                    for _, d in pairs({entries.Box, entries.Name, entries.Distance, entries.Tracer}) do if d then d.Visible = false end end
                    if entries.HealthBar then for _, d in pairs(entries.HealthBar) do if d then d.Visible = false end end end
                    for _, l in pairs(entries.Skeleton) do l.Visible = false end
                end
            else
                local char = plr.Character
                local hrp = char.HumanoidRootPart
                local hum = char.Humanoid
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                
                if onScreen and entries then
                    local dist = (lHRP.Position - hrp.Position).Magnitude
                    local scale = 1 / (pos.Z * math.tan(math.rad(Camera.FieldOfView / 2)) * 2) * 100
                    local width, height = math.floor(6 * scale), math.floor(8 * scale)
                    
                    entries.Box.Visible = ESP.ShowBox; entries.Box.Size = Vector2.new(width, height); entries.Box.Position = Vector2.new(pos.X - width/2, pos.Y - height/2)
                    entries.Name.Visible = ESP.ShowName; entries.Name.Text = plr.Name; entries.Name.Position = Vector2.new(pos.X, pos.Y - height/2 - 15)
                    entries.Distance.Visible = ESP.ShowDistance; entries.Distance.Text = string.format("[%d M]", math.floor(dist)); entries.Distance.Position = Vector2.new(pos.X, pos.Y + height/2 + 2)
                    entries.Tracer.Visible = ESP.ShowTracer; entries.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); entries.Tracer.To = Vector2.new(pos.X, pos.Y + height/2)
                    
                    if ESP.ShowHealth then
                        local hpPercent = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
                        entries.HealthBar.Outline.Visible = true; entries.HealthBar.Outline.Size = Vector2.new(8, height); entries.HealthBar.Outline.Position = Vector2.new(pos.X - width/2 - 12, pos.Y - height/2)
                        entries.HealthBar.Health.Visible = true; entries.HealthBar.Health.Color = Color3.fromRGB(255 * (1 - hpPercent), 255 * hpPercent, 0); entries.HealthBar.Health.Size = Vector2.new(6, height * hpPercent); entries.HealthBar.Health.Position = Vector2.new(pos.X - width/2 - 11, pos.Y + height/2 - (height * hpPercent))
                    else
                        entries.HealthBar.Outline.Visible = false; entries.HealthBar.Health.Visible = false
                    end
                    
                    if ESP.ShowSkeleton then
                        local rigType = hum.RigType == Enum.HumanoidRigType.R15 and "R15" or "R6"
                        for _, conn in ipairs(bodyConnections[rigType] or {}) do
                            local pA, pB = char:FindFirstChild(conn[1]), char:FindFirstChild(conn[2])
                            if pA and pB then
                                local sA, vA = Camera:WorldToViewportPoint(pA.Position); local sB, vB = Camera:WorldToViewportPoint(pB.Position)
                                local k = conn[1].."-"..conn[2]
                                if not entries.Skeleton[k] then entries.Skeleton[k] = newDrawing("Line", { Thickness = 2, Color = Color3.new(1, 1, 1) }) end
                                if vA and vB then entries.Skeleton[k].From = Vector2.new(sA.X, sA.Y); entries.Skeleton[k].To = Vector2.new(sB.X, sB.Y); entries.Skeleton[k].Visible = true else entries.Skeleton[k].Visible = false end
                            end
                        end
                    else
                        for _, l in pairs(entries.Skeleton) do l.Visible = false end
                    end
                elseif entries then
                    -- Off screen handling
                    for _, d in pairs({entries.Box, entries.Name, entries.Distance, entries.Tracer}) do if d then d.Visible = false end end
                    if entries.HealthBar then for _, d in pairs(entries.HealthBar) do if d then d.Visible = false end end end
                    for _, l in pairs(entries.Skeleton) do l.Visible = false end
                end
            end
        end
    end
end)

