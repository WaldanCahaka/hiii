        if state then
            -- ACTION: HIDE (Pindahkan ke ReplicatedStorage)
            WindUI:Notify({ Title = "Visibility Mode", Content = "Menyembunyikan objek...", Duration = 3 })
            
            for _, name in pairs(selectedDelNames) do
                -- Cari objek di Workspace
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name == name then
                        -- Pastikan bukan karakter pemain
                        if obj:IsDescendantOf(LocalPlayer.Character) then continue end
                        
                        -- Simpan Parent asli di Attribute
                        if not obj:GetAttribute("OriginalParent") then
                            obj:SetAttribute("OriginalParent", obj.Parent:GetFullName())
                        end
                        
                        -- Pindahkan ke Storage
                        obj.Parent = hiddenStorage
                    end
                end
            end
        else
            -- ACTION: SHOW (Kembalikan ke Workspace)
            WindUI:Notify({ Title = "Visibility Mode", Content = "Mengembalikan objek...", Duration = 3 })
            
            for _, obj in pairs(hiddenStorage:GetChildren()) do
                local originalPath = obj:GetAttribute("OriginalParent")
                local targetParent = workspace -- Default fallback
                
                -- Coba cari parent asli
                if originalPath then
                    -- Menggunakan string split untuk navigasi path (e.g., Workspace.Map.Trees)
                    local pathParts = string.split(originalPath, ".")
                    local current = game
                    
                    local success = pcall(function()
                        for i, part in ipairs(pathParts) do
                            if i > 1 then -- Lewati "game"
                                if current[part] then
                                    current = current[part]
                                else
                                    break -- Parent sudah tidak ada
                                end
                            end
                        end
                    end)
                    
                    if current and current ~= game then
                        targetParent = current
                    end
                end
                
                -- Kembalikan objek
                obj.Parent = targetParent
                -- Hapus attribute agar bersih
                obj:SetAttribute("OriginalParent", nil)
            end
        end
    end 
})

