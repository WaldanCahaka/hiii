    else
        if invisChair then
            local currentGhostPos = char.HumanoidRootPart.CFrame
            invisChair:Destroy()
            invisChair = nil
            
            char.HumanoidRootPart.CFrame = currentGhostPos * CFrame.new(0, 0, 0)
            task.wait(0.15)
            char.HumanoidRootPart.CFrame = currentGhostPos
            task.wait(0.15)
            char.HumanoidRootPart.CFrame = currentGhostPos * CFrame.new(0, 0, 0)
            
            setTransparency(char, 0)
        end
        invis_on = false
        
        if ghostGuiInstance then
            local btn = ghostGuiInstance:FindFirstChild("GhostButton", true)
            if btn then btn.Text = "Ghost: OFF" end
        end
        if ghostToggleRef then ghostToggleRef:SetState(false) end
    end
end

