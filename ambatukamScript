local function newDrawing(type, props) local drawing = Drawing.new(type) for prop, val in pairs(props) do drawing[prop] = val end return drawing end

local ESP = { Enabled = false, ShowName = false, ShowDistance = false, ShowBox = false, ShowTracer = false, ShowHealth = false, ShowSkeleton = false, Objects = {} }
