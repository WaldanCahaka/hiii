function toggleGhostLogic(state)
    if state == nil then state = not invis_on end

    local char = LocalPlayer.Character
    
    if state then
        if char and char:FindFirstChild("HumanoidRootPart") then
            local savedpos = char.HumanoidRootPart.CFrame
         --   WindUI:Notify({ Title = "Ghost Mode", Content = "Activated.", Duration = 3 })
            
            invisChair = Instance.new('Seat', workspace)
            invisChair.Anchored = false
            invisChair.CanCollide = false
            invisChair.Name = 'invischair'
            invisChair.Transparency = 1
            invisChair.CFrame = savedpos
            
            local Weld = Instance.new("Weld", invisChair)
            Weld.Part0 = invisChair
            Weld.Part1 = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
            
            setTransparency(char, 0.5)
            invis_on = true
            
            if ghostGuiInstance and ghostGuiInstance:FindFirstChild("DragFrame", true) then
                local btn = ghostGuiInstance.DragFrame:FindFirstChild("GhostButton", true)
                if btn then btn.Text = "Ghost: ON" end
            end
            
            if ghostToggleRef then ghostToggleRef:SetState(true) end
        end
    else
        if invisChair then
            local currentGhostPos = char.HumanoidRootPart.CFrame
            invisChair:Destroy()
            invisChair = nil
            
            char.HumanoidRootPart.CFrame = currentGhostPos * CFrame.new(0, 0, 0)
            task.wait(0.15)
            char.HumanoidRootPart.CFrame = currentGhostPos
            task.wait(0.15)
            char.HumanoidRootPart.CFrame = currentGhostPos * CFrame.new(0, 0, 0)
            
            setTransparency(char, 0)
            
        --    WindUI:Notify({ Title = "Ghost Mode", Content = "Deactivated.", Duration = 3 })
        end
        invis_on = false
        
        if ghostGuiInstance and ghostGuiInstance:FindFirstChild("DragFrame", true) then
            local btn = ghostGuiInstance.DragFrame:FindFirstChild("GhostButton", true)
            if btn then btn.Text = "Ghost: OFF" end
        end
        
        if ghostToggleRef then ghostToggleRef:SetState(false) end
    end
end

