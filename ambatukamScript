-- =========================
-- MASTER BYPASS SYSTEM (NOCLIP + SPEED + ANTITELEPORT)
-- =========================
local bypassConnection = nil
local noclipBypassActive = false
local speedBypassActive = false
local customWalkspeed = 16

local function updateBypassLogic()
    -- Jika tidak ada fitur yang aktif, putuskan koneksi
    if not noclipBypassActive and not speedBypassActive then
        if bypassConnection then
            bypassConnection:Disconnect()
            bypassConnection = nil
        end
        -- Reset Normal State
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
            local hum = char:FindFirstChild("Humanoid")
            if hum then hum.WalkSpeed = 16 end
        end
        return
    end

    -- Jika sudah ada koneksi, jangan buat baru (mencegah double loop)
    if bypassConnection then return end

    bypassConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        
        if not hrp or not hum then return end

        -- 1. ANTI-TELEPORT / RESYNC FIX
        -- Mencegah server memaksa karakter kembali ke posisi sebelumnya
        -- Dengan sedikit mengubah posisi Y atau Velocity saat nembus tembok
        if noclipBypassActive then
            -- Logic Noclip (dengan cek tambahan agar tidak error)
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            
            -- Fix Teleport: Mencegah karakter "stuck" di dalam part
            -- Memberikan sedikit dorongan ke atas jika jatuh terlalu cepat atau menembus
            if hrp.Velocity.Y < -100 then
                hrp.Velocity = Vector3.new(hrp.Velocity.X, -50, hrp.Velocity.Z)
            end
        end

        -- 2. WALKSPEED BYPASS
        if speedBypassActive then
            -- Logika Smart Speed:
            -- Jika diam (idle), kunci speed 16 (aman dari anti-cheat idle check).
            -- Jika bergerak (move), paksa speed custom.
            
            if hum.MoveDirection.Magnitude > 0 then
                if hum.WalkSpeed ~= customWalkspeed then
                    hum.WalkSpeed = customWalkspeed
                end
            else
                -- Saat diam, pastikan 16
                if hum.WalkSpeed ~= 16 then
                    hum.WalkSpeed = 16
                end
            end
        end
    end)
end

