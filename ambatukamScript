-- Function: Generate Script (RESPONSIVE WALLHOP)
local function generateWaypointScript()
    if #waypoints < 2 then
        finalScriptString = "-- Error: Titik terlalu sedikit."
        ScriptParagraph:SetDesc("Gagal: Perlu minimal 2 titik jalur.")
        return
    end

    local scriptStr = "-- Ultra Responsive Walker (Wallhop Support)\n"
    scriptStr = scriptStr .. "-- Fix: No Jump Cooldown, Anti-Stuck, Air Control.\n\n"
    
    scriptStr = scriptStr .. "local Players = game:GetService('Players')\n"
    scriptStr = scriptStr .. "local RunService = game:GetService('RunService')\n"
    scriptStr = scriptStr .. "local player = Players.LocalPlayer\n"
    scriptStr = scriptStr .. "local char = player.Character or player.CharacterAdded:Wait()\n"
    scriptStr = scriptStr .. "local hrp = char:WaitForChild('HumanoidRootPart')\n"
    scriptStr = scriptStr .. "local hum = char:WaitForChild('Humanoid')\n\n"

    -- Buat Table Waypoints
    scriptStr = scriptStr .. "local waypoints = {\n"
    for i, wp in ipairs(waypoints) do
        local p = wp.Position
        scriptStr = scriptStr .. string.format("    {Position = Vector3.new(%d, %d, %d), Action = '%s'},\n", p.X, p.Y, p.Z, wp.Action)
    end
    scriptStr = scriptStr .. "}\n\n"

    -- LOGIC RUNNER
    scriptStr = scriptStr .. "local currentWP = 1\n"
    scriptStr = scriptStr .. "local SPEED = 18\n\n"

    scriptStr = scriptStr .. "RunService.Heartbeat:Connect(function()\n"
    scriptStr = scriptStr .. "    if currentWP > #waypoints then return end\n\n"
    
    scriptStr = scriptStr .. "    local wp = waypoints[currentWP]\n"
    scriptStr = scriptStr .. "    local targetPos = wp.Position\n"
    scriptStr = scriptStr .. "    local myPos = hrp.Position\n"
    scriptStr = scriptStr .. "    local dist = (targetPos - myPos).Magnitude\n\n"

    -- ==========================================
    -- 1. LOGIC JUMP (WALLHOP SUPPORT)
    -- ==========================================
    scriptStr = scriptStr .. "    -- Jika ini titik lompat\n"
    scriptStr = scriptStr .. "    if wp.Action == 'Jump' then\n"
    -- PERBAIKAN: Langsung lompat, tidak ada cek "sudah lompat belum" (Anti Cooldown)
    -- Ini memungkinkan lompat ganda cepat untuk Wallhop
    scriptStr = scriptStr .. "        hum:ChangeState(Enum.HumanoidStateType.Jumping)\n"
    
    scriptStr = scriptStr .. "        -- Tentukan target pergerakan\n"
    scriptStr = scriptStr .. "        -- Jika ada titik selanjutnya, kejar titik itu saat di udara\n"
    scriptStr = scriptStr .. "        local nextWP = waypoints[currentWP + 1]\n"
    scriptStr = scriptStr .. "        if nextWP then\n"
    scriptStr = scriptStr .. "            hum:MoveTo(nextWP.Position)\n"
    scriptStr = scriptStr .. "            local dir = (nextWP.Position - myPos).Unit\n"
    -- Dorong kuat saat lompat agar tidak jatuh
    scriptStr = scriptStr .. "            hrp.Velocity = Vector3.new(dir.X * SPEED, hrp.Velocity.Y + 2, dir.Z * SPEED)\n"
    scriptStr = scriptStr .. "        end\n"
    
    -- Skip langsung ke titik selanjutnya agar tidak dobol lompat di titik yang sama
    scriptStr = scriptStr .. "        currentWP = currentWP + 1\n"
    scriptStr = scriptStr .. "        return\n"
    scriptStr = scriptStr .. "    end\n\n"

    -- ==========================================
    -- 2. LOGIC WALK (AGGRESSIVE)
    -- ==========================================
    scriptStr = scriptStr .. "    -- Jalan ke titik saat ini\n"
    scriptStr = scriptStr .. "    hum:MoveTo(targetPos)\n\n"
    
    -- Jika jarak sudah dekat, next
    scriptStr = scriptStr .. "    if dist < 2 then\n"
    scriptStr = scriptStr .. "        currentWP = currentWP + 1\n"
    scriptStr = scriptStr .. "    end\n\n"

    -- Air Control (Jika sedang di udara tapi bukan action lompat)
    scriptStr = scriptStr .. "    if hum.FloorMaterial == Enum.Material.Air then\n"
    scriptStr = scriptStr .. "        local dir = (targetPos - myPos).Unit\n"
    scriptStr = scriptStr .. "        hrp.Velocity = Vector3.new(dir.X * SPEED, hrp.Velocity.Y, dir.Z * SPEED)\n"
    scriptStr = scriptStr .. "    end\n"

    scriptStr = scriptStr .. "end)\n"

    finalScriptString = scriptStr
    ScriptParagraph:SetDesc(string.format("Sukses! %d Titik.\n(Wallhop & Shiftlock Fix)", #waypoints))
end

-- Function: Toggle Recording
local function toggleRecording(state)
    isRecording = state
    
    if isRecording then
        waypoints = {}
        lastRecordedPos = nil
        finalScriptString = ""
        ScriptParagraph:SetDesc("Sedang merekam...")
        
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        
        table.insert(waypoints, {Position = hrp.Position, Action = "Walk"})
        lastRecordedPos = hrp.Position
        
        WindUI:Notify({ Title = "Record", Content = "Recording Started.", Duration = 3 })
        
        recordStepper = RunService.Heartbeat:Connect(function()
            if not isRecording then return end
            local dist = (hrp.Position - lastRecordedPos).Magnitude
            if dist >= MIN_DISTANCE then
                table.insert(waypoints, {Position = hrp.Position, Action = "Walk"})
                lastRecordedPos = hrp.Position
            end
        end)
        
        -- RECORDING: Deteksi Jump tanpa filter
        jumpConnection = hum.StateChanged:Connect(function(old, new)
            if not isRecording then return end
            if new == Enum.HumanoidStateType.Jumping then
                -- Catat titik lompat persis di posisi karakter
                table.insert(waypoints, {Position = hrp.Position, Action = "Jump"})
            end
        end)
        
    else
        if recordStepper then recordStepper:Disconnect() end
        if jumpConnection then jumpConnection:Disconnect() end
        
        WindUI:Notify({ Title = "Record", Content = string.format("Stopped. %d Waypoints captured.", #waypoints), Duration = 3 })
        generateWaypointScript()
    end
end

