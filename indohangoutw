-- */ 6. AUTO FISHING LOGIC (ASLI) /* --
local function InstantThrow()
    if not AutoFishingEnabled then return end
    pcall(function()
        local Rod = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
        if Rod and string.find(Rod.Name:lower(), "rod") then
            RodRemote:FireServer("Throw", Rod, workspace:WaitForChild("Terrain"))
        end
    end)
end
LocalPlayer.Character.ChildAdded:Connect(function(c) if AutoFishingEnabled and c:IsA("Tool") and string.find(c.Name:lower(), "rod") then task.wait(0.3); InstantThrow() end end)
PlayerGui.DescendantRemoving:Connect(function(d) if AutoFishingEnabled and (d.Name == "WhiteBar" or d.Name == "Reeling") then task.wait(1.1); InstantThrow() end end)

