-- */ 1. ENGINE BAR MODE /* --
RunService.RenderStepped:Connect(function()
    if BarMode == "Normal" then return end
    pcall(function()
        for _, gui in pairs(PlayerGui:GetChildren()) do
            local wb = gui:FindFirstChild("WhiteBar", true)
            if wb and wb.Visible then
                if BarMode == "Manual Slider" then
                    wb.Size = UDim2.new(ManualBarSize, 0, wb.Size.Y.Scale, wb.Size.Y.Offset)
                elseif BarMode == "Bar Ngikutin Ikan" then
                    local rb = wb.Parent:FindFirstChild("RedBar") or wb.Parent:FindFirstChild("TargetBar")
                    wb.Size = UDim2.new(0.3, 0, wb.Size.Y.Scale, wb.Size.Y.Offset)
                    if rb then
                        local pos = rb.Position.X.Scale + (rb.Size.X.Scale / 2) - (wb.Size.X.Scale / 2)
                        wb.Position = UDim2.new(pos, wb.Position.X.Offset, wb.Position.Y.Scale, wb.Position.Y.Offset)
                    end
                elseif BarMode == "Full Bar" then
                    wb.Size = UDim2.new(1, 0, wb.Size.Y.Scale, wb.Size.Y.Offset)
                end
            end
        end
    end)
end)

