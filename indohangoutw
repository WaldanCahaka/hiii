    Value = false, 
    Callback = function(s) 
        WalkOnWaterEnabled = s 
        local Player = game:GetService("Players").LocalPlayer
        
        if WalkOnWaterEnabled then
            -- Create Invisible Floor
            WaterPart = Instance.new("Part")
            WaterPart.Name = "WzxX_WaterFloor"
            WaterPart.Size = Vector3.new(10, 1, 10)
            WaterPart.Transparency = 1
            WaterPart.Anchored = true
            WaterPart.Parent = workspace
            
            task.spawn(function()
                while WalkOnWaterEnabled do
                    local char = Player.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if root then
                        -- Deteksi Material di bawah kaki
                        local ray = Ray.new(root.Position, Vector3.new(0, -10, 0))
                        local hit, pos, norm, mat = workspace:FindPartOnRayWithIgnoreList(ray, {char, WaterPart})
                        
                        if mat == Enum.Material.Water then
                            -- Pindahkan balok ke permukaan air
                            WaterPart.CFrame = CFrame.new(root.Position.X, pos.Y - 0.5, root.Position.Z)
                            WaterPart.CanCollide = true
                        else
                            WaterPart.CanCollide = false
                        end
                    end
                    task.wait()
                end
            end)
        else
            -- Cleanup
            if WaterPart then
                WaterPart:Destroy()
                WaterPart = nil
            end
        end
    end 
