-- Daftar nama badge yang dicurigai
local targetBadges = {"HeadAdmin", "Sponsored", "Developer", "Admin"}

-- Fungsi Scan (Hanya jalan kalau AntiAdminEnabled == true)
local function checkAndKick(player)
    -- Jangan cek diri sendiri
    if player == localPlayer then return end

    local function scanCharacter(character)
        -- Cek apakah Fitur ON atau OFF
        if not AntiAdminEnabled then return end

        local head = character:WaitForChild("Head", 10)
        if head then
            local nameTag = head:WaitForChild("NameTag", 5)
            if nameTag then
                local badges = nameTag:WaitForChild("Badges", 5)
                if badges then
                    -- Cek setiap badge di dalam folder Badges
                    for _, badgeName in ipairs(targetBadges) do
                        local badge = badges:FindFirstChild(badgeName)
                        if badge and badge.Visible == true then
                            localPlayer:Kick("\n[WzxX PROTECTION]\nStaff Terdeteksi: " .. player.Name .. "\nBadge: " .. badgeName)
                            return
                        end
                    end
                end
            end
        end
    end

    -- Jalankan scan saat karakter player tersebut muncul
    if player.Character then
        task.spawn(function() scanCharacter(player.Character) end)
    end
    player.CharacterAdded:Connect(scanCharacter)
end

-- Jalankan listener buat semua player
for _, player in ipairs(Players:GetPlayers()) do
    checkAndKick(player)
end
Players.PlayerAdded:Connect(checkAndKick)

