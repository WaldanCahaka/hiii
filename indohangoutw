WaterMoveSection:Toggle({ 
    Title = "Anti-Swim (Deep Walk)", 
    Value = false, 
    Callback = function(s) 
        AntiSwimEnabled = s 
        local Player = game:GetService("Players").LocalPlayer
        
        if AntiSwimEnabled then
            task.spawn(function()
                while AntiSwimEnabled do
                    local char = Player.Character
                    local hum = char and char:FindFirstChild("Humanoid")
                    if hum then
                        -- Matikan state berenang
                        hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
                        
                        -- Paksa lari kalau nyangkut di state berenang
                        if hum:GetState() == Enum.HumanoidStateType.Swimming then
                            hum:ChangeState(Enum.HumanoidStateType.Running)
                        end
                        
                        -- Pemberat Fisik (Density Tinggi)
                        for _, v in pairs(char:GetChildren()) do
                            if v:IsA("BasePart") then
                                v.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        else
            -- RESET
            local char = Player.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then
                hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, true)
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            if char then
                for _, v in pairs(char:GetChildren()) do
                    if v:IsA("BasePart") then
                        v.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
                    end
                end
            end
