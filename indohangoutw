-- */ 5. AUTO FISHING ENGINE /* --
local function InstantThrow()
    if not _G.AutoFishingEnabled then return end
    pcall(function()
        local Rod = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
        if Rod and string.find(Rod.Name:lower(), "rod") then
            RodRemote:FireServer("Throw", Rod, workspace:WaitForChild("Terrain"))
        end
    end)
end

local function SafeThrow()
    task.spawn(function()
        task.wait(0.5) -- Jeda tetap 0.5 detik
        InstantThrow()
    end)
end

local function SetupFishing()
    local Char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    Char.ChildAdded:Connect(function(c) 
        if _G.AutoFishingEnabled and c:IsA("Tool") and string.find(c.Name:lower(), "rod") then 
            SafeThrow()
        end 
    end)
    PlayerGui.DescendantRemoving:Connect(function(d) 
        if _G.AutoFishingEnabled and (d.Name == "WhiteBar" or d.Name == "Reeling") then 
            SafeThrow()
        end 
    end)
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    SetupFishing()
end)

SetupFishing()
if _G.AutoFishingEnabled then SafeThrow() end

