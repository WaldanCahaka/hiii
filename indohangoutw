local function ApplyBadges()
    local char = game.Players.LocalPlayer.Character
    if not char then return end

    local head = char:FindFirstChild("Head")
    if not head then return end

    local nameTag = head:FindFirstChild("NameTag")
    if not nameTag then return end

    local badges = nameTag:FindFirstChild("Badges")
    if not badges then return end

    for badgeName, state in pairs(BadgeStates) do
        local badge = badges:FindFirstChild(badgeName)
        if badge then
            badge.Visible = state
        end
    end
end

-- == SET BADGE ==
local function SetMyBadge(badgeName, state)
    BadgeStates[badgeName] = state
    ApplyBadges()
end

